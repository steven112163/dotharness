#!/usr/bin/env bash
# Shared helpers for ckBuild and ckRun. SOURCED, not executed: defines functions
# and cluster-wide defaults only, with no top-level side effects so callers keep
# control of `set` options and exit behavior.

# Idempotent: sourcing twice (e.g. via nested scripts) must not redefine or error.
[ -n "${_CKCOMMON_SOURCED:-}" ] && return 0
_CKCOMMON_SOURCED=1

# Cluster-wide defaults. Callers may override any via env before sourcing.
IMAGE=${IMAGE:-rocm/composable_kernel:ck_ub24.04_rocm7.1.1_develop}
CONSTRAINT=${CONSTRAINT:-MARKHAM}
CPUS=${CPUS:-128}
SRUN_TIME=${SRUN_TIME:-04:00:00}
SRUN_EXTRA=${SRUN_EXTRA:-}
MAX_NODE_RETRIES=${MAX_NODE_RETRIES:-5}
# Exit code the remote program uses to signal "shared repo not visible on this
# node" (EX_TEMPFAIL); _srun_dispatch excludes the node and retries on this code.
REPO_MISSING_RC=75
# Where the image tarball lives. Shared home, so every node can docker-load it.
IMAGE_DIR=${IMAGE_DIR:-$HOME/images}
# ccache dir. The image defaults to /root/.cache/ccache, unwritable to the
# --user uid; point it at writable shared home (also persists across srun nodes).
CCACHE_DIR=${CCACHE_DIR:-$HOME/.cache/ckBuild-ccache}
# Where generated passwd/group files live (regenerated per run, per uid).
ACCT_DIR=${ACCT_DIR:-$HOME/.cache/ckCommon}
# Slurm job name of the persistent GPU holder (ckHold). When one is running,
# ckRun dispatches into it via `srun --jobid --overlap` (instant, no queue wait).
HOLD_NAME=${HOLD_NAME:-ckhold-$USER}

# Echo the auto-detected backend (direct|docker|srun) for the current host, or
# return 1 with a message if none. srun first (via scontrol ping, not command -v
# srun — the binary may exist on non-Slurm hosts) so a login node dispatches
# rather than building locally; /.dockerenv before docker so an in-container run is not
# re-wrapped. $1: noun for the error message ("build" or "run"). Called in $(...),
# so it must return (not exit) on failure; the caller turns that into an exit.
_detect_backend() {
    if scontrol ping >/dev/null 2>&1; then
        echo srun
    elif [ -f /.dockerenv ]; then
        echo direct
    elif command -v docker >/dev/null 2>&1; then
        echo docker
    elif [ -x /opt/rocm/llvm/bin/clang++ ]; then
        echo direct
    else
        echo "ERROR: no $1 backend found (no Slurm, no docker, no local" >&2
        echo "  /opt/rocm). Set MODE=direct|docker|srun explicitly." >&2
        return 1
    fi
}

# Map a gfx arch to a Slurm GRES request. The :1 count is deliberate: ckRun is
# single-GPU; a multi-GPU sweep overrides GRES wholesale. Extend as new parts appear.
_gres_for_arch() {
    case "$1" in
    gfx942) echo "gpu:gfx942-mi300x:1" ;;
    gfx950) echo "gpu:gfx950-mi350x:1" ;;
    gfx90a) echo "gpu:gfx90a-mi210x:1" ;;
    *) echo "" ;;
    esac
}

# Turn an image ref into a filename-safe tarball basename. The single source of
# truth shared by save (login) and load (node) so the paths always agree.
_sanitized_image_tag() {
    echo "${1:-$IMAGE}" | tr '/:' '__'
}

# On the controlling host: save the image to $IMAGE_DIR/<tag>.tar if absent.
# Idempotent; the daemon already has the image (we built/pulled it on login).
_ensure_image_tar() {
    local image="${1:-$IMAGE}" tar
    tar="$IMAGE_DIR/$(_sanitized_image_tag "$image").tar"
    if [ -f "$tar" ]; then
        return 0
    fi
    echo "Saving image to $tar (one-time, ~tens of GB) ..." >&2
    mkdir -p "$IMAGE_DIR"
    # Save to a temp file and mv into place only on success, so an interrupted
    # save never leaves a partial .tar that a later run trusts and docker-loads.
    local tmp
    tmp=$(mktemp "$tar.XXXXXX") || return 1
    if ! docker save "$image" -o "$tmp"; then
        echo "ERROR: docker save '$image' failed; is it on this daemon?" >&2
        rm -f "$tmp"
        return 1
    fi
    mv -f "$tmp" "$tar"
}

# Build the STATIC docker run flags into the global array DOCKER_FLAGS. These are
# identical on every node (shared home, shared identity), so the srun path can
# serialize them with printf %q and replay them node-side. Per-host flags (the
# account-file binds and GPU group-adds) are added separately by _ACCT_SETUP_SH,
# which must run where docker runs. $1: 1 to expose the GPU, 0 for CPU-only.
# $2: the in-container working directory.
_docker_static_flags() {
    local gpu="$1" workdir="$2"
    # Create the ccache dir on the host so the bind-mount target exists and is
    # owned by the user (docker would otherwise create it root-owned).
    mkdir -p "$CCACHE_DIR"
    # --user keeps repo artifacts owned by the caller, not root.
    DOCKER_FLAGS=(
        --rm
        --user "$(id -u):$(id -g)"
        # $HOME (not just $REPO): dockerRun's old persistent dev container
        # mounted all of $HOME, and dispatched programs reference absolute
        # $HOME-relative paths (e.g. $LIB_DIR under ~/lib/ck-profile) that
        # must resolve identically inside the container.
        -v "$HOME:$HOME"
        # Same repo path inside and out: CK bakes absolute paths and the repo
        # lives at an identical path on every node (shared home).
        -v "$REPO:$REPO" -w "$workdir"
        -e "HOME=$HOME" -e IN_CONTAINER=1
        # ccache dir lives outside $REPO: bind-mount it and point ccache at it,
        # overriding the image's unwritable /root/.cache/ccache default. Kept
        # explicit (redundant when CCACHE_DIR is under $HOME) so a
        # caller-overridden CCACHE_DIR outside $HOME still works.
        -v "$CCACHE_DIR:$CCACHE_DIR" -e "CCACHE_DIR=$CCACHE_DIR"
        --security-opt seccomp=unconfined
    )
    if [ "$gpu" -eq 1 ]; then
        # Device/cap set verified working via dockerRun: bind-mount the device
        # dirs (the proven ROCm pattern). The previous duplicate --device flags
        # were redundant under these binds and are dropped.
        DOCKER_FLAGS+=(--privileged --cap-add=SYS_PTRACE -v /dev/dri:/dev/dri -v /dev/kfd:/dev/kfd)
    fi
}

# Single source of truth for per-host container setup, run wherever docker runs
# (inline for local mode, node-side for srun) so the two paths cannot diverge.
# It builds merged passwd/group files for the caller — the image's accounts plus
# this user's getent entry — so LDAP/SSSD uids resolve to a name inside the
# container (the flat /etc/passwd lacks them). render/video group-adds are
# resolved here too, with node-local gids, only when the GPU is exposed. Inputs:
# $IMAGE, $ACCT_DIR, $_ACCT_GPU. Output: the flag string $_ACCT_FLAGS.
read -r -d '' _ACCT_SETUP_SH <<'SH' || true
_u=$(id -u); _g=$(id -g)
mkdir -p "$ACCT_DIR"
_pw="$ACCT_DIR/passwd-$_u"; _gr="$ACCT_DIR/group-$_u"
# Write to a temp file and mv into place so a killed `docker run` cat never
# leaves a partial account file that a later run would trust.
_t=$(mktemp "$_pw.XXXXXX") && docker run --rm "$IMAGE" cat /etc/passwd >"$_t" && mv -f "$_t" "$_pw"
_t=$(mktemp "$_gr.XXXXXX") && docker run --rm "$IMAGE" cat /etc/group >"$_t" && mv -f "$_t" "$_gr"
cut -d: -f3 "$_pw" | grep -qx "$_u" || getent passwd "$_u" >>"$_pw"
cut -d: -f3 "$_gr" | grep -qx "$_g" || getent group "$_g" >>"$_gr"
_ACCT_FLAGS="-v $_pw:/etc/passwd:ro -v $_gr:/etc/group:ro"
if [ "${_ACCT_GPU:-0}" -eq 1 ]; then
    for _grp in render video; do
        _gid=$(getent group "$_grp" | cut -d: -f3) || _gid=""
        [ -n "$_gid" ] && _ACCT_FLAGS="$_ACCT_FLAGS --group-add $_gid"
    done
fi
SH

# Emit a node-side snippet that loads the image if absent, sets up the account
# files, then runs REMOTE_PROG inside a --rm container. $1: gpu bit, $2: workdir,
# $3: the inner program. Host vars expand here; the inner program is passed
# through literally to the node.
_run_in_container() {
    local gpu="$1" workdir="$2" remote_prog="$3" tar static
    tar="$IMAGE_DIR/$(_sanitized_image_tag "$IMAGE").tar"
    _docker_static_flags "$gpu" "$workdir"
    static=$(printf '%q ' "${DOCKER_FLAGS[@]}")
    # The inner program runs as the container's argv, single-quoted; escape any
    # single quotes within it so the node-side bash -c receives it intact. The
    # '\'' idiom closes the quote, emits an escaped literal quote, then reopens.
    local escaped=${remote_prog//\'/\'\\\'\'}
    cat <<EOF
docker image inspect "$IMAGE" >/dev/null 2>&1 || docker load -i "$tar" >&2
IMAGE="$IMAGE"; ACCT_DIR="$ACCT_DIR"; _ACCT_GPU=$gpu
$_ACCT_SETUP_SH
docker run $static \$_ACCT_FLAGS "$IMAGE" bash -c '$escaped'
EOF
}

# Run a program in a --rm container on THIS host (no srun). $1: gpu bit, $2:
# workdir, $3: the inner program. For the shared-server case: the image is
# auto-pulled by docker run if absent (no tarball). Returns the program's rc.
_docker_run_local() {
    local gpu="$1" workdir="$2" remote_prog="$3" _ACCT_GPU="$1" _ACCT_FLAGS=""
    _docker_static_flags "$gpu" "$workdir"
    eval "$_ACCT_SETUP_SH"
    # --cpus is local only: under srun the cgroupv2 cgroup is threaded and docker
    # --cpus fails to start the container; the srun JOBS clamp handles -j there.
    # _ACCT_FLAGS holds no-space paths under $ACCT_DIR; the word-split is intended.
    # shellcheck disable=SC2086
    docker run "${DOCKER_FLAGS[@]}" --cpus "$CPUS" $_ACCT_FLAGS "$IMAGE" bash -c "$remote_prog"
}

# Echo the job id of the running GPU holder (ckHold), or nothing. Only a RUNNING
# job qualifies; a pending holder cannot be overlapped onto yet.
_hold_jobid() {
    squeue -h -u "$USER" -n "$HOLD_NAME" -t RUNNING -o '%i' 2>/dev/null | head -1
}

# Dispatch into the running GPU holder via `srun --jobid --overlap` (instant, no
# queue wait, fixed node). Returns the program's rc, or 1 if no live holder.
# Reads HOLD_NAME/CPUS/SRUN_EXTRA. The holder owns the GRES, so the overlap step
# requests none.
_srun_overlap_dispatch() {
    local remote_prog="$1" jid
    jid=$(_hold_jobid)
    [ -z "$jid" ] && return 1
    echo "Dispatching into GPU holder job $jid (srun --overlap) ..." >&2
    # shellcheck disable=SC2086
    srun --jobid="$jid" --overlap --cpus-per-task="$CPUS" $SRUN_EXTRA bash -c "$remote_prog"
}

# Dispatch a program via srun with node-exclude retry. Reads GPU/GRES/CONSTRAINT/
# CPUS/SRUN_TIME/SRUN_EXTRA/MAX_NODE_RETRIES/REPO_MISSING_RC. Returns the program's
# rc. On REPO_MISSING_RC it excludes the offending node and retries (some MARKHAM
# nodes have a local /home without the shared repo).
_srun_dispatch() {
    local remote_prog="$1"
    local GRES_FLAG=""
    if [ "$GPU" -eq 1 ]; then
        [ -z "$GRES" ] && {
            echo "ERROR: GPU=1 but no GRES mapping for arch '$ARCH'; set GRES=gpu:...:1." >&2
            return 1
        }
        GRES_FLAG="--gres=$GRES"
    fi
    local CON_FLAG=""
    [ -n "$CONSTRAINT" ] && CON_FLAG="--constraint=$CONSTRAINT"
    local EXCLUDE="" rc=0
    local local_log
    local_log=$(mktemp) || {
        echo "ERROR: mktemp failed; cannot capture srun output." >&2
        return 1
    }
    local _
    for _ in $(seq "$MAX_NODE_RETRIES"); do
        local EX_FLAG=""
        [ -n "$EXCLUDE" ] && EX_FLAG="--exclude=$EXCLUDE"
        echo "Dispatching via srun (${GRES_FLAG:-no-gpu} ${CON_FLAG:-no-constraint} ${EX_FLAG:+$EX_FLAG }--cpus-per-task=$CPUS --time=$SRUN_TIME) ..." >&2
        # Only stderr is teed/logged (the retry grep needs it); stdout stays a
        # clean passthrough for $(...) callers. `wait` lets the tee subshell
        # flush before we grep $local_log. Bare `wait` blocks on every
        # background job in this shell, not just the tee substitution ($! is
        # not set by process substitution); safe today since no caller
        # backgrounds anything before dispatch, but a future caller that
        # does would stall here.
        # ckRun calls _dispatch_run_like as a bare final statement under
        # set -euo pipefail; an unguarded srun failure here would trip set -e
        # before `rc=$?` runs, killing the retry loop. The if/else wraps the
        # command in a conditional (set -e's documented exemption) so rc is
        # always captured regardless of the caller's shielding.
        # shellcheck disable=SC2086
        if srun $GRES_FLAG $CON_FLAG $EX_FLAG --cpus-per-task="$CPUS" --time="$SRUN_TIME" $SRUN_EXTRA bash -c "$remote_prog" 2> >(tee "$local_log" >&2); then
            rc=0
        else
            rc=$?
        fi
        wait
        [ "$rc" -ne "$REPO_MISSING_RC" ] && break
        local bad
        bad=$(grep -oE 'repo not visible on [^ ]+' "$local_log" | awk '{print $5}' | head -1)
        [ -z "$bad" ] && break
        EXCLUDE="${EXCLUDE:+$EXCLUDE,}$bad"
        echo "  node $bad lacks the repo; retrying excluding: $EXCLUDE" >&2
    done
    rm -f "$local_log"
    return "$rc"
}

# Dispatch a build-like (no-overlap) program by MODE: direct runs inline, docker
# runs in a local --rm container, srun ensures the image tarball then dispatches
# via _srun_dispatch. $1: gpu bit, $2: workdir, $3: the inner program. Reads MODE.
# Returns the program's rc, or exits 1 on an unknown MODE (matching ckBuild).
_dispatch_build_like() {
    local gpu="$1" workdir="$2" remote_prog="$3"
    case "$MODE" in
    direct)
        local workdir_escaped=${workdir//\'/\'\\\'\'}
        bash -c "cd '$workdir_escaped' || exit 1; $remote_prog"
        ;;
    docker)
        _docker_run_local "$gpu" "$workdir" "$remote_prog"
        ;;
    srun)
        # gpu (container device passthrough) and GPU (node-scheduling/--gres)
        # are deliberately decoupled here: ckBuild's own GPU-build-node
        # feature passes gpu=0 (no device passthrough needed to build) while
        # having already set the global GPU=1 (schedule on a GPU node,
        # request --gres) before calling this function. Only default GPU
        # from gpu when the caller has not already set it. local (not a bare
        # global assignment) so this never leaks a mutated GPU into the
        # caller's remaining script, symmetric with _dispatch_run_like below.
        local GPU=${GPU:-$gpu}
        _ensure_image_tar "$IMAGE" || return 1
        _srun_dispatch "$(_run_in_container "$gpu" "$workdir" "$remote_prog")"
        ;;
    *)
        echo "ERROR: unknown MODE '$MODE' (want direct|docker|srun)." >&2
        exit 1
        ;;
    esac
}

# Dispatch a run-like program by MODE: direct runs inline, docker runs in a
# local --rm container, srun prefers overlapping into a running GPU holder
# (instant, no queue wait) and falls back to a fresh _srun_dispatch when none is
# held. $1: gpu bit, $2: workdir, $3: the inner program. Reads MODE. Returns the
# program's rc, or exits 1 on an unknown MODE (matching ckRun).
_dispatch_run_like() {
    local gpu="$1" workdir="$2" remote_prog="$3"
    case "$MODE" in
    direct)
        local workdir_escaped=${workdir//\'/\'\\\'\'}
        bash -c "cd '$workdir_escaped' || exit 1; $remote_prog"
        ;;
    docker)
        _docker_run_local "$gpu" "$workdir" "$remote_prog"
        ;;
    srun)
        # Unlike build-like, gpu and GPU are the same concept here (real
        # device passthrough implies scheduling on a GPU node), so the
        # call-site's gpu argument always wins over any ambient GPU already
        # set in the shell (e.g. left over from an unrelated ckBuild/ckRun
        # call), rather than deferring to it.
        local GPU=$gpu
        _ensure_image_tar "$IMAGE" || return 1
        local snippet
        snippet=$(_run_in_container "$gpu" "$workdir" "$remote_prog")
        if [ -n "$(_hold_jobid)" ]; then
            _srun_overlap_dispatch "$snippet"
        else
            _srun_dispatch "$snippet"
        fi
        ;;
    *)
        echo "ERROR: unknown MODE '$MODE' (want direct|docker|srun)." >&2
        exit 1
        ;;
    esac
}

# The rocminfo one-liner used to auto-detect a GPU's gfx arch. Shared by
# _resolve_arch_or_require's direct/docker probe below and ckExec's
# arch_from_container so the two never drift.
_ARCH_PROBE_CMD="rocminfo 2>/dev/null | grep -m1 -oE 'gfx[0-9a-z]+'"

# Validate --arch before it reaches any remote heredoc interpolation. Returns
# (not exits) so a non-fatal caller (e.g. ckCfgProfile) can fall through. $1: arch.
_validate_arch() {
    [[ "$1" =~ ^gfx[0-9a-z]{1,16}$ ]] || {
        echo "ERROR: invalid arch '$1' (expected e.g. gfx942)." >&2
        return 1
    }
}

# Resolve ARCH when empty: srun has no GPU to probe, so it is a hard error;
# direct sits on a GPU host, so probe rocminfo inline; docker probes rocminfo
# inside a container (the host running dockerd may have no GPU/rocminfo of its
# own). $1: MODE. Reads/writes the caller's ARCH variable (bash dynamic
# scoping, as with _gres_for_arch et al.) and reads REPO for the docker probe.
# Prints ckBuild's original error wording and returns 1 on failure to resolve;
# the caller decides whether that is fatal (ckBuild/ckStaticProfile exit on it,
# ckCfgProfile treats arch as best-effort labeling and does not).
_resolve_arch_or_require() {
    local backend="$1"
    if [ -n "$ARCH" ]; then
        _validate_arch "$ARCH" || return 1
        return 0
    fi
    case "$backend" in
    srun)
        echo "ERROR: srun builds run on CPU nodes (no GPU to probe); pass the" >&2
        echo "  target arch, e.g. --arch gfx942 or ARCH=gfx942." >&2
        return 1
        ;;
    direct) ARCH=$(eval "$_ARCH_PROBE_CMD" || true) ;;
    docker)
        local MODE=docker
        ARCH=$(_dispatch_run_like 1 "$REPO" "$_ARCH_PROBE_CMD" 2>/dev/null || true)
        ;;
    esac
    [ -z "$ARCH" ] && {
        echo "ERROR: could not detect GPU arch; pass gfx... or set ARCH=." >&2
        return 1
    }
    return 0
}

# Require ARCH when dispatching to srun (no GPU to probe from a login node);
# computes GRES from it. $1: MODE. Exits 1 with a clear message if ARCH is
# empty on srun. No-op on direct/docker (ARCH/GRES are unused there).
_require_arch_for_srun() {
    local backend="$1"
    [ "$backend" = srun ] || return 0
    if [ -z "$ARCH" ]; then
        echo "ERROR: srun runs dispatch from the login node (no GPU to probe);" >&2
        echo "  pass the arch, e.g. --arch gfx942 or ARCH=gfx942." >&2
        exit 1
    fi
    _validate_arch "$ARCH" || exit 1
    [ -z "$GRES" ] && GRES=$(_gres_for_arch "$ARCH")
}

# Walk up from $1 looking for script/cmake-ck-dev.sh, the CK project root marker.
# Echoes the found directory on success; returns 1 if none is found by /.
_find_ck_root() {
    local d=$1
    while [ "$d" != / ] && [ -n "$d" ]; do
        [ -e "$d/script/cmake-ck-dev.sh" ] && {
            printf '%s\n' "$d"
            return 0
        }
        d=$(dirname "$d")
    done
    return 1
}

# Resolve the caller's REPO variable to the CK project root, walking up from
# REPO then PWD if REPO itself is not already the root. Exits 1 with ckBuild's
# original error message if neither yields a directory with both
# CMakeLists.txt and script/cmake-ck-dev.sh.
_require_ck_root() {
    if [ ! -e "$REPO/script/cmake-ck-dev.sh" ]; then
        local alt
        alt=$(_find_ck_root "$REPO" || _find_ck_root "$PWD") && REPO="$alt"
    fi
    if [ ! -e "$REPO/CMakeLists.txt" ] || [ ! -e "$REPO/script/cmake-ck-dev.sh" ]; then
        echo "ERROR: \$REPO ($REPO) is not the CK project root" >&2
        echo "  (expected CMakeLists.txt and script/cmake-ck-dev.sh)." >&2
        echo "  Set REPO, e.g. REPO=\$(git rev-parse --show-toplevel)." >&2
        exit 1
    fi
}
