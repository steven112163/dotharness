#!/usr/bin/env bash
set -euo pipefail

usage() {
    echo "Usage: $(basename "$0") <image> [container-name]"
    echo "  image          Docker image to run (e.g. ubuntu:22.04)"
    echo "  container-name Name for the container (default: derived from image)"
    exit 1
}

[[ $# -lt 1 || $# -gt 2 ]] && usage

image="$1"
name="${2:-$(echo "$image" | tr '/:' '__')}"

if docker ps -a --format '{{.Names}}' | grep -qx "$name"; then
    echo "Container '$name' already exists. Attach with: docker exec -it $name bash"
    exit 0
fi

# LDAP/SSSD users aren't in the flat /etc/passwd, so the --user uid would be
# nameless inside the container (no home/shell), and attach spawns a shell that
# skips ~/.bashrc. Generate merged account files (image entries + our getent
# entry) via the shared helper in ckCommon, so this and the ckBuild/ckRun path
# cannot diverge. The helper sets _ACCT_FLAGS (the passwd/group bind-mounts plus,
# when _ACCT_GPU=1, the render/video group-adds).
# IMAGE feeds _ACCT_SETUP_SH (consumed via the eval below), not unused.
# shellcheck disable=SC2034
IMAGE="$image"
# shellcheck source=bin/ckCommon disable=SC1091
source "$(dirname "$(readlink -f "$0")")/ckCommon"
_ACCT_GPU=1 _ACCT_FLAGS=""
eval "$_ACCT_SETUP_SH"

# _ACCT_FLAGS holds account-file paths under $ACCT_DIR (no spaces); the word-split
# is intentional.
# shellcheck disable=SC2086
docker run -d -it \
    --security-opt seccomp=unconfined --privileged \
    --network=host \
    --cap-add=SYS_PTRACE \
    --restart=always \
    --name "$name" \
    --user "$(id -u):$(id -g)" \
    $_ACCT_FLAGS \
    -v "$HOME:$HOME" \
    -v /dev/dri:/dev/dri \
    -v /dev/kfd:/dev/kfd \
    -w "$HOME" \
    -e HOME="$HOME" \
    -e IN_CONTAINER=1 \
    -e CONTAINER_NAME="$name" \
    "$image"

echo "Started '$name'. Attach with: docker exec -it $name bash"
