#!/usr/bin/env bash
set -euo pipefail

# Timeline trace of a CK binary with rocprofv3: --sys-trace -> a perfetto
# .pftrace plus CSV. Optionally a best-effort PC-sampling pass.
#
#   ckTraceProfile [--arch gfx...] [--sweep <flag>=<v1,...>] [--nruns N]
#                  [--base-args <args>] [--no-pc-sampling] <bin>

SELF_DIR=$(cd "$(dirname "$(readlink -f "$0")")" && pwd)

# shellcheck source=bin/ckExec disable=SC1091
source "$SELF_DIR/ckExec"

REPO=${REPO:-$(git rev-parse --show-toplevel 2>/dev/null || echo "$PWD")}
ARCH=${ARCH:-}
BIN=${BIN:-}
BASE_ARGS=${BASE_ARGS:--v=0}
SWEEP_FLAG=${SWEEP_FLAG:-}
SWEEP_VALS=${SWEEP_VALS:-}
NRUNS=${NRUNS:-1}
PC_SAMPLING=${PC_SAMPLING:-1}
OUTDIR=${OUTDIR:-}

usage() {
    cat >&2 <<EOF
Usage: $(basename "$0") [--arch gfx...] [--sweep <flag>=<v1,...>]
                        [--nruns N] [--base-args <args>] [--no-pc-sampling] <bin>

  --arch gfx...          GPU arch (e.g. gfx942); required on Slurm
  --sweep <flag>=<vals>  sweep a flag, e.g. --sweep -prec=fp16,bf16
  --nruns N              runs per variant (default: 1)
  --base-args <args>     args passed every run (default: "-v=0")
  --no-pc-sampling       skip the PC-sampling pass (default: attempt it)
  <bin>                  binary path (relative to REPO root, e.g. build/bin/foo)

Env overrides: REPO=$REPO  ARCH=<gfx...>  CONTAINER=<name>  IMAGE=<image>
EOF
    exit 1
}

while [ $# -gt 0 ]; do
    case "$1" in
    -h | --help) usage ;;
    --arch)
        [ $# -ge 2 ] || {
            echo "ERROR: --arch needs a value" >&2
            usage
        }
        ARCH="$2"
        shift 2
        ;;
    --sweep)
        [ $# -ge 2 ] || {
            echo "ERROR: --sweep needs <flag>=<vals>" >&2
            usage
        }
        SWEEP_FLAG="${2%%=*}"
        SWEEP_VALS="${2#*=}"
        shift 2
        ;;
    --nruns)
        [ $# -ge 2 ] || {
            echo "ERROR: --nruns needs a value" >&2
            usage
        }
        NRUNS="$2"
        shift 2
        ;;
    --base-args)
        [ $# -ge 2 ] || {
            echo "ERROR: --base-args needs a value" >&2
            usage
        }
        BASE_ARGS="$2"
        shift 2
        ;;
    --no-pc-sampling) PC_SAMPLING=0 ;;
    -*)
        echo "Unknown option: $1" >&2
        usage
        ;;
    *)
        BIN="$1"
        shift
        ;;
    esac
done

[ -n "$BIN" ] || {
    echo "ERROR: no binary given" >&2
    usage
}
[[ "$BIN" == */* ]] || BIN="build/bin/$BIN"

_find_ck_root() {
    local d="$1"
    while [ -n "$d" ] && [ "$d" != "/" ]; do
        [ -e "$d/script/cmake-ck-dev.sh" ] && {
            printf '%s\n' "$d"
            return 0
        }
        d=$(dirname "$d")
    done
    return 1
}
if [ ! -e "$REPO/$BIN" ]; then
    alt=$(_find_ck_root "$REPO" || _find_ck_root "$PWD") && REPO="$alt"
fi
if [ ! -e "$REPO/$BIN" ]; then
    echo "ERROR: binary not found: $REPO/$BIN" >&2
    exit 1
fi

OUTDIR=${OUTDIR:-$REPO/ck_profile_out/trace}

# shellcheck disable=SC2034  # used by kill_orphans in ckExec
binbase=$(basename "$BIN")

if [ -n "$SWEEP_VALS" ]; then IFS=',' read -ra VARIANTS <<<"$SWEEP_VALS"; else VARIANTS=("default"); fi
rm -rf "$OUTDIR"
mkdir -p "$OUTDIR"
cp "$LIB_DIR/profile_readme.md" "$REPO/ck_profile_out/README.md" 2>/dev/null || true
bash "$LIB_DIR/git_exclude_outdir.sh" "$REPO" 2>/dev/null || true
index="$OUTDIR/index.md"
{
    echo "# trace mode — rocprofv3 timeline"
    echo
    echo "## How to read"
    echo "- **\`raw/<variant>/run_NN/timeline.html\`** — open in Cursor Live Preview (offline)."
    echo "  Host HIP-API lane over GPU dispatch lane; ctrl+wheel zooms, drag pans."
    echo "- **\`raw/<variant>/run_NN/trace_results.pftrace\`** — full perfetto trace."
    echo "  Open https://ui.perfetto.dev and drag in."
    echo "- Look for: gaps between dispatches, serialization, which kernel dominates."
    echo "- Use **dynamic** for absolute numbers; use **trace** for ordering and bubbles."
    echo
    echo "## Traces"
    echo
} >"$index"

for v in "${VARIANTS[@]}"; do
    if [ "$v" = "default" ] || [ -z "$SWEEP_FLAG" ]; then
        args="$BASE_ARGS"
        vlabel="default"
    else
        args="$BASE_ARGS $SWEEP_FLAG=$v"
        vlabel="$v"
    fi
    for i in $(seq 1 "$NRUNS"); do
        rid=$(printf "%02d" "$i")
        out="$OUTDIR/raw/$vlabel/run_$rid"
        mkdir -p "$out"
        if dx "rocprofv3 --sys-trace -f pftrace csv -d '$out' -o trace -- ./$BIN $args >'$out/trace.stdout' 2>'$out/trace.stderr'"; then te=0; else te=$?; fi
        kill_orphans
        pc="skipped"
        if [ "$PC_SAMPLING" = "1" ]; then
            if dx "rocprofv3 --pc-sampling-beta-enabled --pc-sampling-method stochastic --pc-sampling-unit instructions --pc-sampling-interval 1048576 -f csv -d '$out' -o pc -- ./$BIN $args >'$out/pc.stdout' 2>'$out/pc.stderr'"; then
                pc="ok"
            else
                pc="unsupported"
            fi
            kill_orphans
        fi
        pft=$(cd "$out" 2>/dev/null && find . -maxdepth 1 -name '*.pftrace' -printf '%f\n' 2>/dev/null | head -1)
        tl="missing"
        python3 "$LIB_DIR/trace_timeline.py" --run-dir "$out" --prefix trace \
            --name "$vlabel/run_$rid" >/dev/null 2>"$out/timeline.stderr" &&
            [ -s "$out/timeline.html" ] && tl="ok"
        [ -s "$out/timeline.stderr" ] || rm -f "$out/timeline.stderr"
        echo "- **$vlabel** run $rid: trace_exit=$te pc_sampling=$pc timeline=$tl  ->  \`$out/timeline.html\` · \`$out/${pft:-trace.pftrace}\`" >>"$index"
        echo "$vlabel run $rid: trace_exit=$te pc_sampling=$pc timeline=$tl"
    done
done
find "$REPO/.rocprofv3" -mindepth 1 -delete 2>/dev/null || true
rmdir "$REPO/.rocprofv3" 2>/dev/null || true
echo "DONE  (traces in $OUTDIR; see index.md)"
