#!/usr/bin/env bash
set -euo pipefail

# Runtime-profile a CK binary with rocprofv3: kernel trace (runtime + static
# resources) and PMC multipass (L2 hit ratio, HBM fetch/write, occupancy, VALU).
#
#   ckRunProfile [--arch gfx...] [--sweep <flag>=<v1,v2,...>] [--nruns N]
#                [--base-args <args>] <bin>
#
# <bin> is a path to the binary, either absolute or relative to REPO.
# The default is build/bin/<last-path-component> if not a full path.

SELF_DIR=$(cd "$(dirname "$(readlink -f "$0")")" && pwd)

# shellcheck source=bin/ckExec disable=SC1091
source "$SELF_DIR/ckExec"

REPO=${REPO:-$(git rev-parse --show-toplevel 2>/dev/null || echo "$PWD")}
ARCH=${ARCH:-}
BIN=${BIN:-}
BASE_ARGS=${BASE_ARGS:--v=0}
SWEEP_FLAG=${SWEEP_FLAG:-}
SWEEP_VALS=${SWEEP_VALS:-}
NRUNS=${NRUNS:-20}
COUNTERS=${COUNTERS:-$LIB_DIR/counters.txt}
OUTDIR=${OUTDIR:-}

usage() {
    cat >&2 <<EOF
Usage: $(basename "$0") [--arch gfx...] [--sweep <flag>=<v1,...>]
                        [--nruns N] [--base-args <args>] <bin>

  --arch gfx...          GPU arch (e.g. gfx942); required on Slurm
  --sweep <flag>=<vals>  sweep a flag, e.g. --sweep -prec=fp16,bf16
  --nruns N              runs per variant (default: 20)
  --base-args <args>     args passed every run (default: "-v=0")
  <bin>                  binary path (relative to REPO root, e.g. build/bin/foo)

Env overrides: REPO=$REPO  ARCH=<gfx...>  CONTAINER=<name>  IMAGE=<image>
               BIN=  SWEEP_FLAG=  SWEEP_VALS=  NRUNS=  BASE_ARGS=  OUTDIR=
EOF
    exit 1
}

while [ $# -gt 0 ]; do
    case "$1" in
    -h | --help) usage ;;
    --arch)
        [ $# -ge 2 ] || {
            echo "ERROR: --arch needs a value" >&2
            usage
        }
        ARCH="$2"
        shift 2
        ;;
    --sweep)
        [ $# -ge 2 ] || {
            echo "ERROR: --sweep needs <flag>=<vals>" >&2
            usage
        }
        SWEEP_FLAG="${2%%=*}"
        SWEEP_VALS="${2#*=}"
        shift 2
        ;;
    --nruns)
        [ $# -ge 2 ] || {
            echo "ERROR: --nruns needs a value" >&2
            usage
        }
        NRUNS="$2"
        shift 2
        ;;
    --base-args)
        [ $# -ge 2 ] || {
            echo "ERROR: --base-args needs a value" >&2
            usage
        }
        BASE_ARGS="$2"
        shift 2
        ;;
    -*)
        echo "Unknown option: $1" >&2
        usage
        ;;
    *)
        BIN="$1"
        shift
        ;;
    esac
done

[ -n "$BIN" ] || {
    echo "ERROR: no binary given" >&2
    usage
}

# If BIN has no slash, assume it's a target name and look in build/bin/.
[[ "$BIN" == */* ]] || BIN="build/bin/$BIN"

_find_ck_root() {
    local d="$1"
    while [ -n "$d" ] && [ "$d" != "/" ]; do
        [ -e "$d/script/cmake-ck-dev.sh" ] && {
            printf '%s\n' "$d"
            return 0
        }
        d=$(dirname "$d")
    done
    return 1
}
if [ ! -e "$REPO/$BIN" ]; then
    alt=$(_find_ck_root "$REPO" || _find_ck_root "$PWD") && REPO="$alt"
fi
if [ ! -e "$REPO/$BIN" ]; then
    echo "ERROR: binary not found: $REPO/$BIN" >&2
    exit 1
fi

OUTDIR=${OUTDIR:-$REPO/ck_profile_out/dynamic/raw}

# shellcheck disable=SC2034  # used by kill_orphans in ckExec
binbase=$(basename "$BIN")

mkdir -p "$REPO/ck_profile_out"
cp "$LIB_DIR/profile_readme.md" "$REPO/ck_profile_out/README.md" 2>/dev/null || true
bash "$LIB_DIR/git_exclude_outdir.sh" "$REPO" 2>/dev/null || true

cp "$COUNTERS" "$REPO/.ck_profile_counters.txt"
trap 'rm -f "$REPO/.ck_profile_counters.txt"' EXIT
CNT_IN_REPO=.ck_profile_counters.txt

if [ -n "$SWEEP_VALS" ]; then
    IFS=',' read -ra VARIANTS <<<"$SWEEP_VALS"
else
    VARIANTS=("default")
fi

rm -rf "$OUTDIR"
mkdir -p "$OUTDIR"

for v in "${VARIANTS[@]}"; do
    if [ "$v" = "default" ] || [ -z "$SWEEP_FLAG" ]; then
        args="$BASE_ARGS"
        vlabel="default"
    else
        args="$BASE_ARGS $SWEEP_FLAG=$v"
        vlabel="$v"
    fi
    for i in $(seq 1 "$NRUNS"); do
        rid=$(printf "%02d" "$i")
        out="$OUTDIR/$vlabel/run_$rid"
        mkdir -p "$out"
        if dx "rocprofv3 --kernel-trace --stats --summary -T -d '$out' -o t -f csv -- ./$BIN $args >'$out/t.stdout' 2>'$out/t.stderr'"; then te=0; else te=$?; fi
        kill_orphans
        if dx "rocprofv3 -i '$CNT_IN_REPO' -d '$out' -o p -f csv -- ./$BIN $args >'$out/p.stdout' 2>'$out/p.stderr'"; then pe=0; else pe=$?; fi
        kill_orphans
        echo "$vlabel run $rid: trace_exit=$te pmc_exit=$pe"
    done
done
find "$REPO/.rocprofv3" -mindepth 1 -delete 2>/dev/null || true
rmdir "$REPO/.rocprofv3" 2>/dev/null || true
echo "DONE  (raw output in $OUTDIR)"
