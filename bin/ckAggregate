#!/usr/bin/env python3
"""Aggregate rocprofv3 trace + PMC output produced by ckRunProfile.

Counter-set agnostic: it scans every pmc_*/p_counter_collection.csv, so adding
or removing lines in counters.txt does not require editing this script. Every
counter must be classified sum/mean/ignore in COUNTER_CLASS below; an
unclassified counter fails loudly at load time instead of being silently
summed.

For each variant (sweep value), averaged over all runs:
  runtime (total GPU kernel time, program-reported time), L2 hit ratio,
  HBM fetch/write MB, occupancy, VALU%/SALU%/MFMA% busy, memory-unit stall %,
  LDS bank conflicts, wavefronts, achieved HBM bandwidth, roofline-lite verdict.

Usage:
  ckAggregate --raw DIR [--arch gfx942] [--iters N | --marker SUBSTR] [--out DIR]
    [--workload NAME --compute-dir DIR]
"""

import argparse
import csv
import glob
import json
import math
import os
import re
import statistics
import sys

# Bumped whenever summary.json's shape changes; any consumer that parses it by
# field name takes a hard dependency on this value.
SUMMARY_SCHEMA_VERSION = 2

_here = os.path.dirname(os.path.abspath(__file__))
_lib = os.path.join(_here, "..", "lib", "ck-profile")
sys.path.insert(0, _lib)
from gpu_specs import PEAK_MEM_GBS, get_spec  # noqa: E402
import html_report as H  # noqa: E402
from ck_profile_utils import classify, msd, short  # noqa: E402
from compute_report import top_launch_stats_row  # noqa: E402

# Every counter that can appear in a p_counter_collection.csv (i.e. every pmc line in
# counters.txt) must be classified here: "sum" for cumulative counters, "mean" for
# duration-weighted percentages/rates, or "ignore" for ad hoc exploratory counters not
# wired into any reported metric. A counter with no entry fails loudly in
# collect_counters rather than being silently summed.
COUNTER_CLASS = {
    "TCC_HIT": "sum",
    "TCC_MISS": "sum",
    "FETCH_SIZE": "sum",
    "WRITE_SIZE": "sum",
    "MeanOccupancyPerCU": "mean",
    "VALUBusy": "mean",
    "SALUBusy": "mean",
    "MemUnitStalled": "mean",
    "LDSBankConflict": "sum",
    "SQ_VALU_MFMA_BUSY_CYCLES": "sum",
    "SQ_WAVES": "sum",
}


def read_csv(p):
    with open(p) as f:
        return list(csv.DictReader(f))


def trace_metrics(run_dir, marker):
    dom = read_csv(os.path.join(run_dir, "t_domain_stats.csv"))
    total_ns = sum(float(r["TotalDurationNs"]) for r in dom)
    trace = read_csv(os.path.join(run_dir, "t_kernel_trace.csv"))
    n_marker = sum(1 for r in trace if marker and marker in r["Kernel_Name"])
    per = {}
    for r in trace:
        lbl = short(r["Kernel_Name"])
        d = float(r["End_Timestamp"]) - float(r["Start_Timestamp"])
        e = per.setdefault(
            lbl, {"dur": 0.0, "calls": 0, "vgpr": 0, "sgpr": 0, "lds": 0, "scr": 0}
        )
        e["dur"] += d
        e["calls"] += 1
        e["vgpr"] = max(e["vgpr"], int(r["VGPR_Count"]))
        e["sgpr"] = max(e["sgpr"], int(r["SGPR_Count"]))
        e["lds"] = max(e["lds"], int(r["LDS_Block_Size"]))
        e["scr"] = max(e["scr"], int(r["Scratch_Size"]))
    prog_ms = float("nan")
    sp = os.path.join(run_dir, "t.stdout")
    if os.path.exists(sp):
        m = re.search(r"([0-9.]+)\s*ms", open(sp).read())
        if m:
            prog_ms = float(m.group(1))
    return total_ns, n_marker, prog_ms, per


def collect_counters(run_dir):
    """Return {counter: sum} and {counter: duration-weighted mean} over all passes.

    Raises SystemExit if a counter appears with no COUNTER_CLASS entry: add it as
    "sum", "mean", or "ignore" rather than letting it fall through silently.
    """
    sums, wnum, wden = {}, {}, {}
    for f in glob.glob(os.path.join(run_dir, "pmc_*", "p_counter_collection.csv")):
        for r in read_csv(f):
            name = r["Counter_Name"]
            cls = COUNTER_CLASS.get(name)
            if cls is None:
                sys.exit(
                    f"ERROR: counter '{name}' (from {f}) has no sum/mean/ignore "
                    f"classification in ckAggregate's COUNTER_CLASS; add one before re-running."
                )
            if cls == "ignore":
                continue
            val = float(r["Counter_Value"])
            w = float(r["End_Timestamp"]) - float(r["Start_Timestamp"])
            sums[name] = sums.get(name, 0.0) + val
            wnum[name] = wnum.get(name, 0.0) + val * w
            wden[name] = wden.get(name, 0.0) + w
    means = {k: (wnum[k] / wden[k] if wden[k] else 0.0) for k in sums}
    return sums, means


def pmc_metrics(run_dir):
    s, m = collect_counters(run_dir)
    hit, miss = s.get("TCC_HIT", 0.0), s.get("TCC_MISS", 0.0)
    return {
        "hr": 100.0 * hit / (hit + miss) if (hit + miss) else 0.0,
        "fetch_kb": s.get("FETCH_SIZE", 0.0),
        "write_kb": s.get("WRITE_SIZE", 0.0),
        "occ": m.get("MeanOccupancyPerCU", 0.0),
        "valu": m.get("VALUBusy", 0.0),
        "salu": m.get("SALUBusy", 0.0),
        # Raw matrix-engine busy cycles (informational; non-zero = MFMA used).
        # Not converted to a % — that needs per-CU normalization (use omniperf).
        "mfma_cyc": s.get("SQ_VALU_MFMA_BUSY_CYCLES", 0.0),
        "memstall": m.get("MemUnitStalled", 0.0),
        "lds_conf": s.get("LDSBankConflict", 0.0),
        "waves": s.get("SQ_WAVES", 0.0),
    }


def _json_num(x):
    """NaN/inf -> None: json.dump emits bare NaN/Infinity, invalid per RFC 8259."""
    if isinstance(x, float) and (math.isnan(x) or math.isinf(x)):
        return None
    return x


def _fnum(x, fmt):
    """Format a float, or "n/a" for NaN (e.g. a per-wavefront rate with 0 waves)."""
    return "n/a" if isinstance(x, float) and math.isnan(x) else format(x, fmt)


def build_summary_json(overall, arch, unit, peak, occ_sample=None, max_waves=None):
    """Structured twin of summary.md/.html: per-variant verdict + metrics as mean/stdev pairs.

    occ_sample: top-kernel measured occupancy inputs from a sibling
    ckComputeProfile run (see _find_occ_sample), or None if unavailable.
    """

    def ms(pair):
        mean, sd = pair
        return {"mean": _json_num(mean), "stdev": _json_num(sd)}

    return {
        "schema_version": SUMMARY_SCHEMA_VERSION,
        "arch": arch,
        "unit": unit,
        "peak_mem_gbs": _json_num(peak),
        "occ_sample": (
            {
                "kernel": occ_sample["kernel"],
                "vgprs": _json_num(occ_sample["vgprs"]),
                "agprs": _json_num(occ_sample["agprs"]),
                "sgprs": _json_num(occ_sample["sgprs"]),
                "lds_bytes": _json_num(occ_sample["lds_bytes"]),
                "wavefronts": _json_num(occ_sample["wavefronts"]),
                "max_waves_cu": _json_num(max_waves),
            }
            if occ_sample
            else None
        ),
        "variants": [
            {
                "name": name,
                "runs": nr,
                "verdict": verdict,
                "occ_util_pct": _json_num(occu),
                "bw_util_pct": _json_num(bwu),
                "gpu_ms": ms(m["gpu_ms"]),
                "prog_ms": ms(m["prog"]),
                "l2_hit_pct": ms(m["hr"]),
                "fetch_mb": ms(m["fmb"]),
                "write_mb": ms(m["wmb"]),
                "occupancy": ms(m["occ"]),
                "valu_pct": ms(m["valu"]),
                "salu_pct": ms(m["salu"]),
                "mem_stall_pct": ms(m["memstall"]),
                "lds_bank_conflicts": ms(m["lds"]),
                "lds_bank_conflicts_per_wavefront": ms(m["lds_per_wave"]),
                "mfma_busy_cycles": ms(m["mfma_cyc"]),
                "mfma_busy_cycles_per_wavefront": ms(m["mfma_per_wave"]),
                "wavefronts": ms(m["waves"]),
                "achieved_bw_gbs": ms(m["bw"]),
            }
            for name, nr, m, bwu, verdict, occu in overall
        ],
    }


def write_html(overall, pk_rows, spec, peak, arch, unit, out, occ_sample=None):
    def sv(x, s=""):
        return f"{x}{s}" if x is not None else "n/a"

    parts = [
        "<h1>CK dynamic profiling</h1>",
        f"<p class='sub'>arch <b>{H.esc(arch)}</b>"
        + (f" &middot; peak mem BW {peak} GB/s" if peak else "")
        + f" &middot; normalization <b>{H.esc(unit)}</b></p>",
    ]

    if occ_sample:
        parts.append(
            H.section(
                f"Measured occupancy sample — {H.esc(occ_sample['kernel'])} "
                "(from a sibling ckComputeProfile run)",
                "<div class='card'><div class='grid2'>"
                f"<div>VGPRs: <b>{sv(occ_sample['vgprs'])}</b></div>"
                f"<div>AGPRs: <b>{sv(occ_sample['agprs'])}</b></div>"
                f"<div>SGPRs: <b>{sv(occ_sample['sgprs'])}</b></div>"
                f"<div>LDS allocation: <b>{sv(occ_sample['lds_bytes'], ' B')}</b></div>"
                f"<div>Total wavefronts: <b>{sv(occ_sample['wavefronts'])}</b></div>"
                f"<div>max waves/CU (ceiling): <b>{sv(occ_sample['max_waves_cu'])}</b></div>"
                "</div><p class='sub'>Top kernel by time in the compute-mode run for this "
                "workload — not a per-kernel join with the table below. Not a limiter "
                "classification; compare each value against its cap to judge which is "
                "tightest.</p></div>",
            )
        )

    if spec:
        rows = [
            [
                sv(spec["cu"]),
                sv(spec["wave"]),
                sv(spec["simd_per_cu"]),
                sv(spec["max_waves_cu"]),
                sv(spec["vgpr_per_simd"]),
                sv(spec["agpr_per_simd"]),
                sv(spec["lds_kb_per_cu"], " KB"),
                sv(peak, " GB/s"),
            ]
        ]
        parts.append(
            H.section(
                f"Device spec — {arch} ({spec['product']})",
                H.table(
                    [
                        "CUs",
                        "wave",
                        "SIMD/CU",
                        "max waves/CU",
                        "VGPR/SIMD",
                        "AGPR/SIMD",
                        "LDS/CU",
                        "peak mem BW",
                    ],
                    rows,
                    num_cols=range(8),
                ),
            )
        )

    gms = [
        (name, m["gpu_ms"][0], f"{m['gpu_ms'][0]:.4f} ms")
        for name, _, m, _, _, _ in overall
    ]
    parts.append(
        H.section(
            f"Runtime across variants ({unit}, lower is better)",
            f"<div class='card'>{H.bars(gms)}</div>",
        )
    )

    cards = []
    for name, nr, m, bwu, verdict, occu in overall:
        g = H.gauges(
            [
                ("occ util % (achieved/max waves)", occu),
                ("BW util %", bwu),
                ("VALU %", m["valu"][0]),
                ("SALU %", m["salu"][0]),
                ("mem-stall %", m["memstall"][0]),
                ("L2 hit %", m["hr"][0]),
            ]
        )
        nums = (
            "<div class='grid2'>"
            + f"<div>gpu_ms: <b>{m['gpu_ms'][0]:.4f}</b> &plusmn; {m['gpu_ms'][1]:.3f}</div>"
            + f"<div>occupancy: <b>{m['occ'][0]:.2f}</b> waves/CU</div>"
            + f"<div>achieved BW: <b>{m['bw'][0]:.1f}</b> GB/s</div>"
            + f"<div>fetch / write: <b>{m['fmb'][0]:.2f}</b> / <b>{m['wmb'][0]:.2f}</b> MB</div>"
            + f"<div>LDS bank conflicts / wavefront: <b>{_fnum(m['lds_per_wave'][0], '.3f')}</b></div>"
            + f"<div>MFMA busy cycles / wavefront: <b>{_fnum(m['mfma_per_wave'][0], '.1f')}</b></div>"
            + "</div>"
        )
        cards.append(
            f"<div class='card'><div class='row'><h3>{H.esc(name)} "
            f"&nbsp; ({nr} runs)</h3>&nbsp;{H.badge(verdict)}</div>{g}{nums}</div>"
        )
    parts.append(H.section("Per-variant roofline metrics", "".join(cards)))

    for name, *_ in overall:
        rows = pk_rows.get(name, [])
        items = [
            (r[0], r[3], f"{r[2]} µs ({r[3]}%)") for r in rows[:12]
        ]  # label, pct, disp
        parts.append(
            H.section(
                f"Per-kernel breakdown — {name} ({unit})",
                f"<div class='card'>{H.bars(items, max_value=100.0)}</div>",
            )
        )

    parts.append(
        "<p class='foot'>Self-contained report — CSS/SVG bars, no external "
        "dependencies. Companion files: summary.md, summary.json, "
        "summary_overall.csv, per_kernel_*.csv.</p>"
    )
    with open(os.path.join(out, "summary.html"), "w") as f:
        f.write(H.page(f"CK dynamic profiling — {arch}", "".join(parts)))


def _find_occ_sample(compute_dir, workload):
    """Top-kernel measured occupancy inputs from a sibling ckComputeProfile
    run, joined by workload (binary basename). None if either arg is empty,
    the compute run doesn't exist, or its Launch Stats panel isn't found."""
    if not compute_dir or not workload:
        return None
    csvdir = os.path.join(compute_dir, "raw", f"{workload}_csv")
    if not os.path.isdir(csvdir):
        return None
    return top_launch_stats_row(csvdir)


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--raw", required=True)
    ap.add_argument("--arch", default="gfx942")
    ap.add_argument("--iters", type=int, default=0)
    ap.add_argument("--marker", default="")
    ap.add_argument("--out", default="")
    ap.add_argument(
        "--peak-gbs",
        type=float,
        default=0.0,
        help="override peak device-memory bandwidth (GB/s); needed for "
        "exact RDNA SKUs since one gfx ID covers many cards",
    )
    ap.add_argument(
        "--workload",
        default="",
        help="binary basename, for joining a sibling ckComputeProfile run "
        "(matches ckComputeProfile's own --workload default)",
    )
    ap.add_argument(
        "--compute-dir",
        default="",
        help="path to a ckComputeProfile run dir (e.g. ck_profile_out/compute/latest); "
        "adds a measured occupancy sample for --workload if found there",
    )
    a = ap.parse_args()
    out = a.out or os.path.dirname(a.raw.rstrip("/")) or "."
    peak = a.peak_gbs or PEAK_MEM_GBS.get(a.arch)
    spec = get_spec(a.arch)
    max_waves = spec["max_waves_cu"] if spec else None
    occ_sample = _find_occ_sample(a.compute_dir, a.workload)

    variants = sorted(
        d for d in glob.glob(os.path.join(a.raw, "*")) if os.path.isdir(d)
    )
    overall = []
    pk_rows = {}  # variant -> list of per-kernel rows (for markdown + CSV)
    for vd in variants:
        name = os.path.basename(vd)
        runs = sorted(glob.glob(os.path.join(vd, "run_*")))
        if not runs:
            continue
        acc = {
            k: []
            for k in [
                "gpu_ms",
                "prog",
                "hr",
                "fmb",
                "wmb",
                "occ",
                "valu",
                "salu",
                "mfma_cyc",
                "memstall",
                "lds",
                "lds_per_wave",
                "mfma_per_wave",
                "waves",
                "bw",
            ]
        }
        kern = {}
        for rd in runs:
            try:
                total_ns, nmark, pms, per = trace_metrics(rd, a.marker)
                p = pmc_metrics(rd)
            except FileNotFoundError:
                continue
            div = a.iters or (nmark if a.marker and nmark else 1)
            acc["gpu_ms"].append(total_ns / div / 1e6)
            acc["prog"].append(pms)
            acc["hr"].append(p["hr"])
            acc["fmb"].append(p["fetch_kb"] / 1024.0 / div)
            acc["wmb"].append(p["write_kb"] / 1024.0 / div)
            acc["occ"].append(p["occ"])
            acc["valu"].append(p["valu"])
            acc["salu"].append(p["salu"])
            acc["mfma_cyc"].append(p["mfma_cyc"] / div)
            acc["memstall"].append(p["memstall"])
            acc["lds"].append(p["lds_conf"] / div)
            # Per-wavefront rate (div cancels: both sides are per-run raw sums),
            # so it stays comparable across runs with different --nruns/--iters.
            acc["lds_per_wave"].append(
                p["lds_conf"] / p["waves"] if p["waves"] else float("nan")
            )
            acc["mfma_per_wave"].append(
                p["mfma_cyc"] / p["waves"] if p["waves"] else float("nan")
            )
            acc["waves"].append(p["waves"] / div)
            acc["bw"].append(
                (p["fetch_kb"] + p["write_kb"]) * 1024.0 / (total_ns / 1e9) / 1e9
            )
            for lbl, e in per.items():
                k = kern.setdefault(
                    lbl,
                    {
                        "us": [],
                        "calls": e["calls"] // max(div, 1),
                        "vgpr": e["vgpr"],
                        "sgpr": e["sgpr"],
                        "lds": e["lds"],
                        "scr": e["scr"],
                    },
                )
                k["us"].append(e["dur"] / div / 1e3)
        m = {k: msd(v) for k, v in acc.items()}
        bw_util = 100.0 * m["bw"][0] / peak if peak else float("nan")
        compute_util = max(m["valu"][0], m["salu"][0])
        verdict = classify(compute_util, bw_util) if peak else "n/a (unknown arch peak)"
        occ_util = 100.0 * m["occ"][0] / max_waves if max_waves else float("nan")
        overall.append((name, len(runs), m, bw_util, verdict, occ_util))

        tot = sum(statistics.mean(k["us"]) for k in kern.values()) or 1
        rows = []
        for lbl, k in sorted(kern.items(), key=lambda x: -statistics.mean(x[1]["us"])):
            us = statistics.mean(k["us"])
            rows.append(
                [
                    lbl,
                    k["calls"],
                    round(us, 2),
                    round(100 * us / tot, 1),
                    k["vgpr"],
                    k["sgpr"],
                    k["lds"],
                    k["scr"],
                ]
            )
        pk_rows[name] = rows
        with open(os.path.join(out, f"per_kernel_{name}.csv"), "w", newline="") as f:
            w = csv.writer(f)
            w.writerow(
                [
                    "kernel",
                    "calls",
                    "us_total",
                    "pct",
                    "VGPR",
                    "SGPR",
                    "LDS_bytes",
                    "scratch",
                ]
            )
            w.writerows(rows)

    with open(os.path.join(out, "summary_overall.csv"), "w", newline="") as f:
        w = csv.writer(f)
        w.writerow(
            [
                "variant",
                "runs",
                "gpu_ms",
                "gpu_ms_sd",
                "prog_ms",
                "L2_hit_pct",
                "fetch_MB",
                "write_MB",
                "occupancy",
                "occ_util_pct",
                "valu_pct",
                "salu_pct",
                "mem_stall_pct",
                "lds_bank_conflicts",
                "lds_bank_conflicts_per_wavefront",
                "mfma_busy_cycles",
                "mfma_busy_cycles_per_wavefront",
                "wavefronts",
                "achieved_BW_GBs",
                "BW_util_pct",
                "verdict",
            ]
        )
        for name, nr, m, bwu, verdict, occu in overall:
            w.writerow(
                [
                    name,
                    nr,
                    f"{m['gpu_ms'][0]:.4f}",
                    f"{m['gpu_ms'][1]:.4f}",
                    f"{m['prog'][0]:.4f}",
                    f"{m['hr'][0]:.2f}",
                    f"{m['fmb'][0]:.3f}",
                    f"{m['wmb'][0]:.3f}",
                    f"{m['occ'][0]:.2f}",
                    f"{occu:.1f}",
                    f"{m['valu'][0]:.2f}",
                    f"{m['salu'][0]:.2f}",
                    f"{m['memstall'][0]:.2f}",
                    f"{m['lds'][0]:.0f}",
                    _fnum(m["lds_per_wave"][0], ".3f"),
                    f"{m['mfma_cyc'][0]:.0f}",
                    _fnum(m["mfma_per_wave"][0], ".1f"),
                    f"{m['waves'][0]:.0f}",
                    f"{m['bw'][0]:.1f}",
                    f"{bwu:.1f}",
                    verdict,
                ]
            )

    unit = "per-iter" if (a.iters or a.marker) else "per-run"

    def sv(x, suffix=""):  # spec value, or "n/a" when unverified/unreleased
        return f"{x}{suffix}" if x is not None else "n/a"

    # --- markdown summary (readable report) ---
    md = [
        "# dynamic mode — runtime profiling summary",
        "",
        f"- arch: **{a.arch}**  (peak mem BW {peak} GB/s)"
        if peak
        else f"- arch: **{a.arch}**",
        f"- normalization: **{unit}**",
        "",
        "## How to read",
        "",
        "- Open **`summary.html`** for the charted version (offline). This `.md` is the "
        "same data as text; `summary_overall.csv` + `per_kernel_*.csv` are for scripts; "
        "`raw/` holds the per-run rocprofv3 CSVs.",
        "- **Per-variant table** is the headline. The two ratios that drive the "
        "**verdict**: *occ util %* (achieved occupancy ÷ ceiling) and *BW util %* "
        "(achieved ÷ peak HBM). Low both + low VALU% = latency/occupancy-bound; high "
        "VALU% = compute-bound; high BW% = memory-bound.",
        "- **Per-kernel breakdown** ranks kernels by time; pair a hot kernel's VGPR/LDS "
        "here with the static report's occupancy ceiling to see if registers cap it.",
        "- Numbers are mean ± stdev over the runs, normalized per the unit above.",
        "",
    ]
    if occ_sample:
        md += [
            f"## Measured occupancy sample — {occ_sample['kernel']}",
            "",
            "Top kernel by time in a sibling ckComputeProfile run for this workload — "
            "not a per-kernel join with the tables below. Not a limiter classification.",
            "",
            "| VGPRs | AGPRs | SGPRs | LDS allocation (B) | total wavefronts | max waves/CU |",
            "| --- | --- | --- | --- | --- | --- |",
            f"| {sv(occ_sample['vgprs'])} | {sv(occ_sample['agprs'])} | "
            f"{sv(occ_sample['sgprs'])} | {sv(occ_sample['lds_bytes'])} | "
            f"{sv(occ_sample['wavefronts'])} | {sv(occ_sample['max_waves_cu'])} |",
            "",
        ]
    if spec:
        md += [
            f"## Device spec — {a.arch} ({spec['product']})",
            "",
            "| CUs | wave | SIMD/CU | max waves/CU | VGPR/SIMD | AGPR/SIMD | LDS/CU | peak mem BW |",
            "| --- | --- | --- | --- | --- | --- | --- | --- |",
            f"| {sv(spec['cu'])} | {sv(spec['wave'])} | {sv(spec['simd_per_cu'])} | "
            f"{sv(spec['max_waves_cu'])} | {sv(spec['vgpr_per_simd'])} | {sv(spec['agpr_per_simd'])} | "
            f"{sv(spec['lds_kb_per_cu'], ' KB')} | {sv(peak, ' GB/s')} |",
            "",
            "max waves/CU is the occupancy ceiling; the **occ util %** column below is "
            "achieved occupancy as a fraction of it. n/a = value not published for this arch.",
            "",
        ]
    md += [
        "## Per-variant metrics",
        "",
        "| variant | runs | gpu_ms | L2 hit % | fetch MB | write MB | occ/CU | occ util % | VALU % | SALU % | mem-stall % | BW GB/s | BW util % | verdict |",
        "| --- | --- | --- | --- | --- | --- | --- | --- | --- | --- | --- | --- | --- | --- |",
    ]
    for name, nr, m, bwu, verdict, occu in overall:
        md.append(
            f"| {name} | {nr} | {m['gpu_ms'][0]:.4f} ± {m['gpu_ms'][1]:.3f} | "
            f"{m['hr'][0]:.1f} | {m['fmb'][0]:.2f} | {m['wmb'][0]:.2f} | {m['occ'][0]:.2f} | "
            f"{occu:.1f} | {m['valu'][0]:.2f} | {m['salu'][0]:.2f} | {m['memstall'][0]:.2f} | "
            f"{m['bw'][0]:.1f} | {bwu:.1f} | **{verdict}** |"
        )
    md += [
        "",
        "## Per-wavefront rates",
        "",
        "Raw `lds_bank_conflicts`/`mfma_busy_cycles` sums scale with `--nruns`/`--iters`; "
        "these per-wavefront rates stay comparable across runs with different settings.",
        "",
        "| variant | LDS bank conflicts / wavefront | MFMA busy cycles / wavefront |",
        "| --- | --- | --- |",
    ]
    for name, _, m, *_ in overall:
        md.append(
            f"| {name} | {_fnum(m['lds_per_wave'][0], '.3f')} | "
            f"{_fnum(m['mfma_per_wave'][0], '.1f')} |"
        )
    for name, *_ in overall:
        md += [
            "",
            f"## Per-kernel breakdown — {name} ({unit})",
            "",
            "| kernel | calls | µs | % | VGPR | SGPR | LDS B | scratch |",
            "| --- | --- | --- | --- | --- | --- | --- | --- |",
        ]
        for r in pk_rows.get(name, [])[:12]:
            md.append("| " + " | ".join(str(c) for c in r) + " |")
    with open(os.path.join(out, "summary.md"), "w") as f:
        f.write("\n".join(md) + "\n")

    write_html(overall, pk_rows, spec, peak, a.arch, unit, out, occ_sample)

    with open(os.path.join(out, "summary.json"), "w") as f:
        json.dump(
            build_summary_json(overall, a.arch, unit, peak, occ_sample, max_waves),
            f,
            indent=2,
            allow_nan=False,
        )
        f.write("\n")

    if spec:
        print(
            f"arch={a.arch} ({spec['product']})  CUs={sv(spec['cu'])}  wave={sv(spec['wave'])}  "
            f"max_waves/CU={sv(spec['max_waves_cu'])}  peak_mem={peak} GB/s  normalization={unit}"
        )
    else:
        print(f"arch={a.arch}  peak_mem={peak} GB/s  normalization={unit}")
    print(
        f"{'variant':9} {'runs':4} {'gpu_ms':>8} {'L2%':>6} {'fetMB':>7} {'wrMB':>7} "
        f"{'occ':>5} {'occ%':>6} {'VALU%':>6} {'SALU%':>6} {'memStl%':>7} {'BW%':>5}  verdict"
    )
    for name, nr, m, bwu, verdict, occu in overall:
        print(
            f"{name:9} {nr:4d} {m['gpu_ms'][0]:8.4f} {m['hr'][0]:6.1f} {m['fmb'][0]:7.2f} "
            f"{m['wmb'][0]:7.2f} {m['occ'][0]:5.2f} {occu:6.1f} {m['valu'][0]:6.2f} {m['salu'][0]:6.2f} "
            f"{m['memstall'][0]:7.2f} {bwu:5.1f}  {verdict}"
        )
    print(
        f"\nwrote {os.path.join(out, 'summary.html')}, summary.md, summary.json, "
        "summary_overall.csv, per_kernel_*.csv"
    )


if __name__ == "__main__":
    main()
