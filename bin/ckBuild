#!/usr/bin/env bash
set -euo pipefail

# Build a Composable Kernel (CK) tree inside the CK docker image, auto-detecting
# how to reach a build node.
#
# Two build shapes, one command:
#   - incremental (default): reuse the existing build/ tree, just rebuild. With
#     the Ninja generator, ninja itself re-runs CMake when CMakeLists change, so
#     editing sources or build files needs no manual reconfigure.
#   - scratch (--scratch): wipe build/ and configure from zero. Use this after
#     changing the GPU arch, toolchain, or cmake options, where an incremental
#     reconfigure is unsafe.
#
# The build runs in a --rm container off the CK image, so the toolchain comes
# from the image (self-consistent gcc/amdclang++/ccache) rather than the host.
# That removes host-toolchain skew. CK cross-compiles, so the build needs no GPU.
#
# Backend is auto-detected (override with MODE=direct|docker|srun):
#   - srun   : a Slurm login node (srun present). Dispatches the build as ONE
#              srun allocation on a CPU node, running it inside the image via
#              docker run --rm (image distributed as a save/load tarball).
#   - docker : a shared server with docker but no srun. Runs the build in a
#              --rm container on this host (image auto-pulled if absent).
#   - direct : already inside the dev container (/.dockerenv), or a bare box with
#              local /opt/rocm. Runs inline (the surrounding env IS the toolchain).
#
# A login-node container without srun cannot be told apart from a shared-server
# container; both auto-detect to direct. Force MODE=srun there to require srun.
#
# The repo path is assumed identical on the build node (shared filesystem on the
# cluster, bind mount in the container). Override anything via env vars.

# shellcheck source=bin/ckCommon disable=SC1091
source "$(dirname "$(readlink -f "$0")")/ckCommon"

REPO=${REPO:-$(git rev-parse --show-toplevel 2>/dev/null || echo "$PWD")}
ARCH=${ARCH:-}
BUILD_DIR=${BUILD_DIR:-build}
# GPU=0: build on a CPU node (default; container supplies the toolchain, CK
# cross-compiles). GPU=1: build on a GPU node (--gres).
GPU=${GPU:-0}
GRES=${GRES:-}
MODE=${MODE:-}

# Guard early: a non-numeric GPU (e.g. GPU=true) would make `[ "$GPU" -eq 1 ]`
# error to stderr yet fall through as if GPU=0, silently dropping --gres.
case "$GPU" in
0 | 1) ;;
*)
    echo "ERROR: GPU must be 0 or 1 (got '$GPU')." >&2
    exit 1
    ;;
esac

usage() {
    cat >&2 <<EOF
Usage: $(basename "$0") [--scratch] [--minimal] [gfx...] [target...] [-- <extra cmake args>]

  --scratch     wipe $BUILD_DIR/ and configure from zero (default: incremental)
  --minimal     pass --minimal to cmake-ck-dev.sh (fewer instances, faster build)
  gfx...        GPU arch (e.g. gfx942); same as ARCH=. Required in srun mode
                (CPU build node, nothing to probe). Needs --scratch to take
                effect on an already-configured tree. direct/docker: auto-detect.
  target...     ninja targets to build (default: all)
  -- <args>     extra args forwarded to cmake-ck-dev.sh on (re)configure
                (each must be space-free; they are re-split on the build node)

Backend auto-detection (override with MODE): direct | docker | srun
Env overrides: IMAGE=$IMAGE  REPO=$REPO
               ARCH=<gfx...>  BUILD_DIR=$BUILD_DIR  MODE=<backend>
               GPU=$GPU (0 = CPU build node, default; 1 = GPU node, --gres)
               GRES=<gpu:...:1>  CONSTRAINT=$CONSTRAINT (Slurm site; clear to allow any)
               CPUS=$CPUS (srun --cpus-per-task; build uses all of them)
               SRUN_TIME=$SRUN_TIME  SRUN_EXTRA=<srun args>  IMAGE_DIR=$IMAGE_DIR
EOF
    exit 1
}

SCRATCH=0
MINIMAL=""
TARGETS=()
EXTRA_CMAKE=()
while [ $# -gt 0 ]; do
    case "$1" in
    --scratch) SCRATCH=1 ;;
    --minimal) MINIMAL="--minimal" ;;
    -h | --help) usage ;;
    --)
        shift
        EXTRA_CMAKE=("$@")
        break
        ;;
    -*)
        echo "Unknown option: $1" >&2
        usage
        ;;
    gfx*) ARCH="$1" ;;
    *) TARGETS+=("$1") ;;
    esac
    shift
done

# TARGETS/EXTRA_CMAKE are re-split by word on the build node, so a whitespace-
# bearing element would silently mangle rather than pass through. Reject it with a
# clear error instead of producing a corrupt command line.
for _a in ${TARGETS[@]+"${TARGETS[@]}"} ${EXTRA_CMAKE[@]+"${EXTRA_CMAKE[@]}"}; do
    case "$_a" in
    *[[:space:]]*)
        echo "ERROR: argument '$_a' contains whitespace; targets and extra cmake" >&2
        echo "  args are re-split on the build node and must be space-free." >&2
        exit 1
        ;;
    esac
done

# Resolve REPO to the CK project root even if cwd drifted into a subdir: walk up
# looking for script/cmake-ck-dev.sh. Fail fast rather than configure in the
# wrong place.
_find_ck_root() {
    local d=$1
    while [ "$d" != / ] && [ -n "$d" ]; do
        [ -e "$d/script/cmake-ck-dev.sh" ] && {
            printf '%s\n' "$d"
            return 0
        }
        d=$(dirname "$d")
    done
    return 1
}
if [ ! -e "$REPO/script/cmake-ck-dev.sh" ]; then
    alt=$(_find_ck_root "$REPO" || _find_ck_root "$PWD") && REPO="$alt"
fi
if [ ! -e "$REPO/CMakeLists.txt" ] || [ ! -e "$REPO/script/cmake-ck-dev.sh" ]; then
    echo "ERROR: \$REPO ($REPO) is not the CK project root" >&2
    echo "  (expected CMakeLists.txt and script/cmake-ck-dev.sh)." >&2
    echo "  Set REPO, e.g. REPO=\$(git rev-parse --show-toplevel)." >&2
    exit 1
fi

# Pick the backend (see _detect_backend in ckCommon for the precedence rule).
[ -n "$MODE" ] || MODE=$(_detect_backend build) || exit 1
echo "Backend: $MODE"

# srun builds on CPU nodes (no GPU to probe) require an explicit arch; direct and
# docker run on a GPU host, so rocminfo can probe it there.
if [ -z "$ARCH" ]; then
    case "$MODE" in
    srun)
        echo "ERROR: srun builds run on CPU nodes (no GPU to probe); pass the" >&2
        echo "  target arch, e.g. 'ckBuild gfx942' or ARCH=gfx942." >&2
        exit 1
        ;;
    # direct/docker assume a local GPU host: probe the host's rocminfo. If the
    # docker host has no local ROCm, pass the arch explicitly.
    direct | docker) ARCH=$(rocminfo 2>/dev/null | grep -m1 -oE 'gfx[0-9a-z]+' || true) ;;
    esac
    [ -z "$ARCH" ] && {
        echo "ERROR: could not detect GPU arch; pass gfx... or set ARCH=." >&2
        exit 1
    }
fi
[ "$GPU" -eq 1 ] && [ -z "$GRES" ] && GRES=$(_gres_for_arch "$ARCH")

BUILD_ABS="$REPO/$BUILD_DIR"

# Touch the shared filesystem here, not on the build node.
if [ "$SCRATCH" -eq 1 ]; then
    echo "Scratch build: removing $BUILD_ABS"
    rm -rf "$BUILD_ABS"
fi
mkdir -p "$BUILD_ABS"

# Configure on scratch or first run; ninja auto-reconfigures incrementally.
if [ "$SCRATCH" -eq 1 ] || [ ! -f "$BUILD_ABS/build.ninja" ]; then
    NEED_CONFIGURE=1
else
    NEED_CONFIGURE=0
    echo "Incremental build: reusing $BUILD_ABS"
fi

# Program run on the build node (inside the container under srun, inline under
# direct). Host vars ($REPO, $BUILD_ABS, $ARCH, $MINIMAL, $MODE, $NEED_CONFIGURE,
# the arrays) expand now, when the heredoc is built; \$VARS stay literal and are
# evaluated on the build node.
REMOTE_PROG=$(
    cat <<EOF
set -o pipefail
if [ ! -e "$REPO/script/cmake-ck-dev.sh" ]; then
    echo "ERROR: repo not visible on \$(hostname -s) ($REPO missing)." >&2
    echo "  Landed on a node without your shared home; srun mode auto-retries." >&2
    exit $REPO_MISSING_RC
fi
cd "$BUILD_ABS"
if [ "$NEED_CONFIGURE" -eq 1 ]; then
    CACHE_FLAGS=""
    if command -v ccache >/dev/null 2>&1; then
        CACHE_FLAGS="-DCMAKE_HIP_COMPILER_LAUNCHER=ccache -DCMAKE_CXX_COMPILER_LAUNCHER=ccache -DCMAKE_C_COMPILER_LAUNCHER=ccache"
    elif command -v sccache >/dev/null 2>&1; then
        CACHE_FLAGS="-DCMAKE_HIP_COMPILER_LAUNCHER=sccache -DCMAKE_CXX_COMPILER_LAUNCHER=sccache -DCMAKE_C_COMPILER_LAUNCHER=sccache"
    fi
    echo "Configuring ($ARCH) in $BUILD_ABS ..."
    # Fatal: pipefail alone would let a failed configure fall through to ninja.
    ../script/cmake-ck-dev.sh $MINIMAL .. $ARCH -G Ninja \$CACHE_FLAGS ${EXTRA_CMAKE[*]:-} || exit 1
fi
# srun owns the allocation: use the reserved core budget, clamped to what the
# container actually sees (it is --cpus-capped, so nproc reflects the reservation,
# but clamp anyway in case the cap is absent). direct shares the box, so use half
# the cores capped at 128 to stay responsive and keep CK's memory-hungry template
# compiles from OOMing on very large hosts.
if [ "$MODE" = srun ]; then
    JOBS=\${SLURM_CPUS_PER_TASK:-$CPUS}; _n=\$(nproc); [ \$JOBS -gt \$_n ] && JOBS=\$_n
else
    JOBS=\$(( \$(nproc) / 2 )); [ \$JOBS -gt 128 ] && JOBS=128
fi
[ \$JOBS -lt 1 ] && JOBS=1
echo "Building ${TARGETS[*]:-all} with -j\$JOBS ..."
ninja -j\$JOBS ${TARGETS[*]:-} 2>&1 | tee build.log
EOF
)

run_build() {
    case "$MODE" in
    direct)
        bash -c "$REMOTE_PROG"
        ;;
    docker)
        # --rm container on this host; no GPU device needed (CPU cross-compile).
        _docker_run_local 0 "$BUILD_ABS" "$REMOTE_PROG"
        ;;
    srun)
        _ensure_image_tar "$IMAGE" || return 1
        _srun_dispatch "$(_run_in_container 0 "$BUILD_ABS" "$REMOTE_PROG")"
        ;;
    *)
        echo "ERROR: unknown MODE '$MODE' (want direct|docker|srun)." >&2
        exit 1
        ;;
    esac
}

# NFS caveat: artifacts written by the container on a compute node take a few
# seconds to appear on the login node (attribute caching). Trust run_build's exit
# code; do not stat/read build/ outputs immediately to "verify" success.
if run_build; then
    echo "Build successful (log: $BUILD_ABS/build.log)"
else
    echo "Build failed (log: $BUILD_ABS/build.log)" >&2
    exit 1
fi
