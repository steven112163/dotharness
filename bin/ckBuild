#!/usr/bin/env bash
set -euo pipefail

# Build a Composable Kernel (CK) tree, auto-detecting how to reach a build node.
#
# Two build shapes, one command:
#   - incremental (default): reuse the existing build/ tree, just rebuild. With
#     the Ninja generator, ninja itself re-runs CMake when CMakeLists change, so
#     editing sources or build files needs no manual reconfigure.
#   - scratch (--scratch): wipe build/ and configure from zero. Use this after
#     changing the GPU arch, toolchain, or cmake options, where an incremental
#     reconfigure is unsafe.
#
# Backend is auto-detected (override with MODE=direct|srun|docker):
#   - direct : already on a build node. Chosen inside a container (/.dockerenv)
#              or inside a Slurm allocation ($SLURM_JOB_ID set), or as the final
#              fallback when /opt/rocm is present locally. Runs commands inline.
#   - srun   : a Slurm login node (srun present). Dispatches the whole
#              configure+build as ONE srun allocation, so the queue is hit once.
#              Requests a GPU node (GPU=1) for a uniform ROCm toolchain; pass an
#              explicit arch. GPU=0 builds on a CPU node (cross-compile) instead.
#   - docker : a plain docker host (no Slurm). Dispatches into the dev container
#              via `docker exec`, creating it on demand. The other-server flow.
#
# The repo path is assumed identical on the build node (shared filesystem on the
# cluster, bind mount in the container). Override anything via env vars.

CONTAINER=${CONTAINER:-styuan_dev}
IMAGE=${IMAGE:-rocm/composable_kernel:ck_ub24.04_rocm7.1.1_develop}
REPO=${REPO:-$(git rev-parse --show-toplevel 2>/dev/null || echo "$PWD")}
ARCH=${ARCH:-}
BUILD_DIR=${BUILD_DIR:-build}
# TheRock pip ROCm venv toolchain on shared home; auto-created. Empty = /opt/rocm.
VENV=${VENV:-$HOME/rocm-venv}
ROCM_PKG=${ROCM_PKG:-rocm[libraries,devel]==7.13.0}
ROCM_INDEX=${ROCM_INDEX:-https://repo.amd.com/rocm/whl/gfx94X-dcgpu/}
# ccache has no pip wheel; fetch the upstream static binary into the venv bin.
CCACHE_VERSION=${CCACHE_VERSION:-4.10.2}
# GPU=1: build on a GPU node (--gres). GPU=0: CPU-only node (no --gres).
GPU=${GPU:-1}
GRES=${GRES:-}
CONSTRAINT=${CONSTRAINT:-MARKHAM}
CPUS=${CPUS:-128}
SRUN_TIME=${SRUN_TIME:-04:00:00}
SRUN_EXTRA=${SRUN_EXTRA:-}
MODE=${MODE:-}
MAX_NODE_RETRIES=${MAX_NODE_RETRIES:-5}
# Exit code the remote program uses to signal "shared repo not visible on this
# node" (EX_TEMPFAIL); srun mode excludes the node and retries on this code.
REPO_MISSING_RC=75

# Guard early: a non-numeric GPU (e.g. GPU=true) would make `[ "$GPU" -eq 1 ]`
# error to stderr yet fall through as if GPU=0, silently dropping --gres.
case "$GPU" in
0 | 1) ;;
*)
    echo "ERROR: GPU must be 0 or 1 (got '$GPU')." >&2
    exit 1
    ;;
esac

usage() {
    cat >&2 <<EOF
Usage: $(basename "$0") [--scratch] [--minimal] [gfx...] [target...] [-- <extra cmake args>]

  --scratch     wipe $BUILD_DIR/ and configure from zero (default: incremental)
  --minimal     pass --minimal to cmake-ck-dev.sh (fewer instances, faster build)
  gfx...        GPU arch (e.g. gfx942); same as ARCH=. Required in srun mode
                (CPU build node, nothing to probe). Needs --scratch to take
                effect on an already-configured tree. direct/docker: auto-detect.
  target...     ninja targets to build (default: all)
  -- <args>     extra args forwarded to cmake-ck-dev.sh on (re)configure
                (each must be space-free; they are re-split on the build node)

Backend auto-detection (override with MODE): direct | srun | docker
Env overrides: CONTAINER=$CONTAINER  IMAGE=<image>  REPO=$REPO
               ARCH=<gfx...>  BUILD_DIR=$BUILD_DIR  MODE=<backend>
               VENV=$VENV (ROCm toolchain; auto-created, set empty for /opt/rocm)
               GPU=$GPU (1 = GPU node, default; 0 = CPU-only node, no --gres)
               GRES=<gpu:...:1>  CONSTRAINT=$CONSTRAINT (Slurm site; clear to allow any)
               CPUS=$CPUS (srun --cpus-per-task; build uses all of them)
               SRUN_TIME=$SRUN_TIME  SRUN_EXTRA=<srun args>
EOF
    exit 1
}

SCRATCH=0
MINIMAL=""
TARGETS=()
EXTRA_CMAKE=()
while [ $# -gt 0 ]; do
    case "$1" in
    --scratch) SCRATCH=1 ;;
    --minimal) MINIMAL="--minimal" ;;
    -h | --help) usage ;;
    --)
        shift
        EXTRA_CMAKE=("$@")
        break
        ;;
    -*)
        echo "Unknown option: $1" >&2
        usage
        ;;
    gfx*) ARCH="$1" ;;
    *) TARGETS+=("$1") ;;
    esac
    shift
done

# Resolve REPO to the CK project root even if cwd drifted into a subdir: walk up
# looking for script/cmake-ck-dev.sh. Fail fast rather than configure in the
# wrong place.
_find_ck_root() {
    local d=$1
    while [ "$d" != / ] && [ -n "$d" ]; do
        [ -e "$d/script/cmake-ck-dev.sh" ] && {
            printf '%s\n' "$d"
            return 0
        }
        d=$(dirname "$d")
    done
    return 1
}
if [ ! -e "$REPO/script/cmake-ck-dev.sh" ]; then
    alt=$(_find_ck_root "$REPO" || _find_ck_root "$PWD") && REPO="$alt"
fi
if [ ! -e "$REPO/CMakeLists.txt" ] || [ ! -e "$REPO/script/cmake-ck-dev.sh" ]; then
    echo "ERROR: \$REPO ($REPO) is not the CK project root" >&2
    echo "  (expected CMakeLists.txt and script/cmake-ck-dev.sh)." >&2
    echo "  Set REPO, e.g. REPO=\$(git rev-parse --show-toplevel)." >&2
    exit 1
fi

# Pick the backend. Precedence: inside a container or a Slurm allocation -> run
# inline; else a login node with srun -> dispatch via srun; else a docker host
# -> dispatch via docker; else a bare box with local ROCm -> run inline.
if [ -z "$MODE" ]; then
    if [ -f /.dockerenv ] || [ -n "${SLURM_JOB_ID:-}" ]; then
        MODE=direct
    elif command -v srun >/dev/null 2>&1; then
        MODE=srun
    elif command -v docker >/dev/null 2>&1; then
        MODE=docker
    elif [ -x /opt/rocm/llvm/bin/clang++ ]; then
        MODE=direct
    else
        echo "ERROR: no build backend found (no container, no Slurm, no docker," >&2
        echo "  no local /opt/rocm). Set MODE=direct|srun|docker explicitly." >&2
        exit 1
    fi
fi
echo "Backend: $MODE"

# Map a gfx arch to a Slurm GRES request. Extend as new parts appear.
_gres_for_arch() {
    case "$1" in
    gfx942) echo "gpu:gfx942-mi300x:1" ;;
    gfx950) echo "gpu:gfx950-mi350x:1" ;;
    gfx90a) echo "gpu:gfx90a-mi210x:1" ;;
    *) echo "" ;;
    esac
}

# srun builds on CPU nodes (no GPU to probe) require an explicit arch; direct/docker probe.
if [ -z "$ARCH" ]; then
    case "$MODE" in
    srun)
        echo "ERROR: srun builds run on CPU nodes (no GPU to probe); pass the" >&2
        echo "  target arch, e.g. 'ckBuild gfx942' or ARCH=gfx942." >&2
        exit 1
        ;;
    direct) ARCH=$(rocminfo 2>/dev/null | grep -m1 -oE 'gfx[0-9a-z]+' || true) ;;
    docker) ARCH=$(docker exec "$CONTAINER" bash -c "rocminfo 2>/dev/null | grep -m1 -oE 'gfx[0-9a-z]+'" 2>/dev/null || true) ;;
    esac
    [ -z "$ARCH" ] && {
        echo "ERROR: could not detect GPU arch; pass gfx... or set ARCH=." >&2
        exit 1
    }
fi
[ "$GPU" -eq 1 ] && [ -z "$GRES" ] && GRES=$(_gres_for_arch "$ARCH")

# Bootstrap the venv if missing (on the controlling host: has pip + network).
# The "ready" marker is bin/activate, but `python3 -m venv` creates that before
# the pip installs run; a failed install would leave a partial venv that the
# guard then treats as ready. Wipe the half-built venv on any bootstrap failure.
if [ -n "$VENV" ] && [ ! -f "$VENV/bin/activate" ]; then
    echo "Creating ROCm venv at $VENV (one-time, ~16GB) ..."
    trap 'echo "ERROR: venv bootstrap failed; removing partial $VENV" >&2; rm -rf "$VENV"' ERR
    python3 -m venv "$VENV"
    # shellcheck disable=SC1091
    source "$VENV/bin/activate"
    pip install --quiet --upgrade pip
    pip install --quiet cmake ninja
    pip install --index-url "$ROCM_INDEX" --extra-index-url https://pypi.org/simple "$ROCM_PKG"
    # Drop a static ccache into the venv bin so the launcher guard always finds it.
    cc_tar="ccache-${CCACHE_VERSION}-linux-x86_64"
    if curl -fsSL "https://github.com/ccache/ccache/releases/download/v${CCACHE_VERSION}/${cc_tar}.tar.xz" |
        tar -xJ -C "$VENV/bin" --strip-components=1 "${cc_tar}/ccache" 2>/dev/null; then
        echo "Installed ccache ${CCACHE_VERSION} into $VENV/bin"
    else
        echo "WARNING: could not fetch ccache; builds will run without a compiler cache." >&2
    fi
    deactivate
    trap - ERR
fi

BUILD_ABS="$REPO/$BUILD_DIR"

# Touch the shared filesystem here, not on the build node.
if [ "$SCRATCH" -eq 1 ]; then
    echo "Scratch build: removing $BUILD_ABS"
    rm -rf "$BUILD_ABS"
fi
mkdir -p "$BUILD_ABS"

# Configure on scratch or first run; ninja auto-reconfigures incrementally.
if [ "$SCRATCH" -eq 1 ] || [ ! -f "$BUILD_ABS/build.ninja" ]; then
    NEED_CONFIGURE=1
else
    NEED_CONFIGURE=0
    echo "Incremental build: reusing $BUILD_ABS"
    if ! grep -q 'COMPILER_LAUNCHER' "$BUILD_ABS/CMakeCache.txt" 2>/dev/null; then
        echo "  hint: this tree has no compiler-cache launcher; run --scratch once to attach ccache/sccache." >&2
    fi
fi

# Program run on the build node. Host vars ($REPO, $VENV, $BUILD_ABS, $ARCH,
# $MINIMAL, $MODE, $NEED_CONFIGURE, the arrays) expand now, when the heredoc is
# built; \$VARS stay literal and are evaluated on the build node.
REMOTE_PROG=$(
    cat <<EOF
set -o pipefail
if [ ! -e "$REPO/script/cmake-ck-dev.sh" ]; then
    echo "ERROR: repo not visible on \$(hostname -s) ($REPO missing)." >&2
    echo "  Landed on a node without your shared home; srun mode auto-retries." >&2
    exit $REPO_MISSING_RC
fi
# Use the venv toolchain if present on this node, else system ROCm.
USE_VENV=0
if [ -n "$VENV" ] && [ -f "$VENV/bin/activate" ]; then
    # shellcheck disable=SC1091
    source "$VENV/bin/activate"
    ROCM_ROOT=\$(rocm-sdk path --root)
    VCXX="\$ROCM_ROOT/lib/llvm/bin/amdclang++"
    USE_VENV=1
    echo "Toolchain: venv ($VENV)"
else
    echo "Toolchain: system /opt/rocm"
fi
cd "$BUILD_ABS"
if [ "$NEED_CONFIGURE" -eq 1 ]; then
    CACHE_FLAGS=""
    if command -v ccache >/dev/null 2>&1; then
        CACHE_FLAGS="-DCMAKE_HIP_COMPILER_LAUNCHER=ccache -DCMAKE_CXX_COMPILER_LAUNCHER=ccache -DCMAKE_C_COMPILER_LAUNCHER=ccache"
    elif command -v sccache >/dev/null 2>&1; then
        CACHE_FLAGS="-DCMAKE_HIP_COMPILER_LAUNCHER=sccache -DCMAKE_CXX_COMPILER_LAUNCHER=sccache -DCMAKE_C_COMPILER_LAUNCHER=sccache"
    fi
    # GCC 14's libstdc++ <format> header (bits/unicode.h) has an invalid "++this;"
    # that amdclang++ rejects. Pin clang to the newest GCC below 14 on this node.
    GCC_FLAG=""
    for v in 13 12 11; do
        if [ -d "/usr/lib/gcc/x86_64-linux-gnu/\$v" ]; then
            GCC_FLAG="--gcc-install-dir=/usr/lib/gcc/x86_64-linux-gnu/\$v"
            echo "Pinning clang to GCC \$v (avoids GCC 14 unicode.h bug)"
            break
        fi
    done
    # Venv flags override the preset's /opt/rocm compiler (trailing -D wins).
    VENV_FLAGS=""
    if [ "\$USE_VENV" -eq 1 ]; then
        # Pin clang-tidy to the venv; else find_program grabs /opt/rocm's, which
        # is ABI-incompatible and crashes with "free(): invalid pointer".
        VENV_FLAGS="-DCMAKE_HIP_ARCHITECTURES=$ARCH -DCMAKE_PREFIX_PATH=\$ROCM_ROOT -DCMAKE_CXX_COMPILER=\$VCXX -DCMAKE_HIP_COMPILER=\$VCXX -DCMAKE_HIP_COMPILER_ROCM_ROOT=\$ROCM_ROOT -DCLANG_TIDY_EXE=\$ROCM_ROOT/lib/llvm/bin/clang-tidy -DCMAKE_POLICY_VERSION_MINIMUM=3.5"
    fi
    # Pass via COMPILER_ARG1 so the preset's CMAKE_CXX_FLAGS stays intact.
    GCC_CMAKE=""
    [ -n "\$GCC_FLAG" ] && GCC_CMAKE="-DCMAKE_CXX_COMPILER_ARG1=\$GCC_FLAG -DCMAKE_HIP_COMPILER_ARG1=\$GCC_FLAG"
    echo "Configuring ($ARCH) in $BUILD_ABS ..."
    # Fatal: pipefail alone would let a failed configure fall through to ninja.
    ../script/cmake-ck-dev.sh $MINIMAL .. $ARCH -G Ninja \$CACHE_FLAGS \$VENV_FLAGS \$GCC_CMAKE ${EXTRA_CMAKE[*]:-} || exit 1
fi
# srun owns the allocation: use all cores. Other modes share the box, so use
# half the cores capped at 128 to stay responsive and keep CK's memory-hungry
# template compiles from OOMing on very large hosts.
if [ "$MODE" = srun ]; then
    JOBS=\$(nproc)
else
    JOBS=\$(( \$(nproc) / 2 )); [ \$JOBS -gt 128 ] && JOBS=128
fi
[ \$JOBS -lt 1 ] && JOBS=1
echo "Building ${TARGETS[*]:-all} with -j\$JOBS ..."
ninja -j\$JOBS ${TARGETS[*]:-} 2>&1 | tee build.log
EOF
)

run_build() {
    case "$MODE" in
    direct)
        bash -c "$REMOTE_PROG"
        ;;
    srun)
        GRES_FLAG=""
        if [ "$GPU" -eq 1 ]; then
            [ -z "$GRES" ] && {
                echo "ERROR: GPU=1 but no GRES mapping for arch '$ARCH'; set GRES=gpu:...:1." >&2
                exit 1
            }
            GRES_FLAG="--gres=$GRES"
        fi
        CON_FLAG=""
        [ -n "$CONSTRAINT" ] && CON_FLAG="--constraint=$CONSTRAINT"
        # Some MARKHAM nodes have a local /home without the repo (guard exits 75);
        # retry, excluding each bad node, until one mounts the shared home.
        EXCLUDE=""
        local local_log
        local_log=$(mktemp) || {
            echo "ERROR: mktemp failed; cannot capture srun output." >&2
            return 1
        }
        local rc=0
        for _ in $(seq "$MAX_NODE_RETRIES"); do
            EX_FLAG=""
            [ -n "$EXCLUDE" ] && EX_FLAG="--exclude=$EXCLUDE"
            echo "Dispatching via srun (${GRES_FLAG:-no-gpu} ${CON_FLAG:-no-constraint} ${EX_FLAG:+$EX_FLAG }--cpus-per-task=$CPUS --time=$SRUN_TIME) ..."
            # shellcheck disable=SC2086
            srun $GRES_FLAG $CON_FLAG $EX_FLAG --cpus-per-task="$CPUS" --time="$SRUN_TIME" $SRUN_EXTRA bash -c "$REMOTE_PROG" 2>&1 | tee "$local_log"
            rc=${PIPESTATUS[0]}
            [ "$rc" -ne "$REPO_MISSING_RC" ] && break
            bad=$(grep -oE 'repo not visible on [^ ]+' "$local_log" | awk '{print $5}' | head -1)
            [ -z "$bad" ] && break
            EXCLUDE="${EXCLUDE:+$EXCLUDE,}$bad"
            echo "  node $bad lacks the repo; retrying excluding: $EXCLUDE" >&2
        done
        rm -f "$local_log"
        return "$rc"
        ;;
    docker)
        if ! docker ps --filter "name=^${CONTAINER}$" --format '{{.Names}}' | grep -q .; then
            echo "Container '$CONTAINER' not running; creating via ~/bin/dockerRun ..."
            "$HOME/bin/dockerRun" "$IMAGE" "$CONTAINER"
        fi
        docker exec -w "$BUILD_ABS" "$CONTAINER" bash -c "$REMOTE_PROG"
        ;;
    *)
        echo "ERROR: unknown MODE '$MODE' (want direct|srun|docker)." >&2
        exit 1
        ;;
    esac
}

if run_build; then
    echo "Build successful (log: $BUILD_ABS/build.log)"
else
    echo "Build failed (log: $BUILD_ABS/build.log)" >&2
    exit 1
fi
